# Enforce LF line endings for all text files
* text=auto eol=lf

# PHP
*.php text eol=lf

# CSS
*.css text eol=lf
*.scss text eol=lf

# HTML / Templates
*.html text eol=lf

# JavaScript
*.js text eol=lf
*.ts text eol=lf

# Data / Config
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.pot text eol=lf
*.po text eol=lf
*.mo binary

# Git meta
.gitattributes text eol=lf
.gitignore text eol=lf
.distignore text eol=lf
.editorconfig text eol=lf

# Binary — do not modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.zip binary
